  "name": "Helios Platform Dev Environment",
  "description": "Complete development environment for Helios Platform with PowerShell, Node.js, Python, and Docker",

  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
