  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/root/.ssh,readonly",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/root/.gitconfig,readonly",
    "source=/var/run/docker.sock,target=/var/run/docker.sock",
    "type=volume,source=node_modules,target=/workspace/node_modules",
    "type=volume,source=python_cache,target=/workspace/.venv"
