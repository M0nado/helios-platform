    "stages": ["Incoming", "PendingScan", "PendingApproval", "Sanitized", "Rejected", "Outgoing", "Receipts"],
    "requiredReceiptFields": [
      "correlationId",
      "source",
      "destination",
      "originalSha256",
      "sanitizedSha256",
      "fileType",
      "signatureStatus",
      "scannerVersions",
      "findings",
      "sandboxResult",
      "policyDecision",
      "approvingIdentity",
      "approvedAt",
      "rollbackInstructions"
    ],
    "highRiskTypes": ["driver", "kernel-component", "unsigned-script", "executable", "unknown-model", "firmware", "certificate"],
    "highRiskApproval": "sysadmin-physical-two-factor"
  },
