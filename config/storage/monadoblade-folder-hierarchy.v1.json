    "denyExecutionFromIncomingAndPending": true,
    "requireCatalogManifestForSoftwarePromotion": true,
    "requireSbomWhenSupported": true,
    "requireSha256": true,
    "requireSignatureCheckWhenSupported": true,
    "requireRollbackReceipt": true,
    "preserveRejectedEvidenceByPolicy": true
