{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "defaultProfile": "personal",
  "profiles": [
    {
      "id": "developer",
      "displayName": "Developer",
      "windowsRole": "standard-user",
      "interactive": true,
      "admin": false,
      "color": "#00D8FF",
      "glyph": "DEV",
      "soundCue": "profile-developer",
      "background": "grass-grid-aurora",
      "softwareBundles": ["common-core", "developer-core", "developer-ai", "developer-azure", "developer-native"],
      "roots": ["dev", "models-read", "common", "crosspartition", "telemetry-user"],
      "resourcePolicy": {
        "cpuMode": "build-throughput",
        "gpuMode": "balanced-compute",
        "memoryReserveGb": 8,
        "containerBudgetGb": 24,
        "vmBudgetGb": 32,
        "modelBudgetGb": 24,
        "backgroundPriority": "normal"
      },
      "networkPolicy": "developer-approved-egress",
      "aihubMode": "code-build-test-route-optimize",
      "dashboardWidgets": ["builds", "repos", "models", "containers", "vms", "cpu", "gpu", "memory", "security"]
    },
    {
      "id": "sysadmin",
      "displayName": "SysAdmin",
      "windowsRole": "local-administrator",
      "interactive": true,
      "admin": true,
      "hidden": true,
      "enabledByDefault": false,
      "activation": {
        "physicalPresenceRequired": true,
        "minimumFactors": 2,
        "allowedFactors": ["fido2", "encrypted-usb-token", "windows-hello", "offline-recovery-secret"],
        "remoteActivationDenied": true,
        "cloudActivationDenied": true,
        "aiActivationDenied": true
      },
      "color": "#FFB000",
      "glyph": "ROOT",
      "soundCue": "profile-sysadmin",
      "background": "sealed-vault-grass-night",
      "softwareBundles": ["common-core-minimal", "sysadmin-security", "sysadmin-recovery", "sysadmin-driver-disk"],
      "roots": ["all-gated"],
      "resourcePolicy": {
        "cpuMode": "stability-first",
        "gpuMode": "minimal",
        "memoryReserveGb": 12,
        "containerBudgetGb": 0,
        "vmBudgetGb": 16,
        "modelBudgetGb": 4,
        "backgroundPriority": "security-critical"
      },
      "networkPolicy": "local-first-restricted",
      "aihubMode": "recommend-only-no-autonomous-admin",
      "dashboardWidgets": ["integrity", "drivers", "secureboot", "tpm", "bitlocker", "firewall", "quarantine", "recovery"]
    },
    {
      "id": "sysops",
      "displayName": "SysOps",
      "windowsRole": "standard-user-bounded-operator",
      "interactive": true,
      "admin": false,
      "color": "#2D7DFF",
      "glyph": "OPS",
      "soundCue": "profile-sysops",
      "background": "operations-constellation",
      "softwareBundles": ["common-core", "sysops-security", "sysops-observability", "sysops-cloud", "sysops-performance"],
      "roots": ["dev-read", "server-ops", "telemetry", "common", "crosspartition", "quarantine-read"],
      "resourcePolicy": {
        "cpuMode": "observability-responsive",
        "gpuMode": "balanced",
        "memoryReserveGb": 10,
        "containerBudgetGb": 20,
        "vmBudgetGb": 40,
        "modelBudgetGb": 12,
        "backgroundPriority": "high"
      },
      "networkPolicy": "infra-vpn-monitored",
      "aihubMode": "security-performance-operations",
      "dashboardWidgets": ["services", "firewall", "network", "latency", "vms", "containers", "memory", "disks", "azure", "github-actions", "incidents"]
    },
    {
      "id": "gamer",
      "displayName": "Gamer",
      "windowsRole": "standard-user",
      "interactive": true,
      "admin": false,
      "color": "#62FF4A",
      "glyph": "PLAY",
      "soundCue": "profile-gamer",
      "background": "energy-field-green",
      "softwareBundles": ["common-core", "gamer-launchers", "gamer-capture", "gamer-peripherals"],
      "roots": ["games", "common", "crosspartition-sanitized", "captures"],
      "resourcePolicy": {
        "cpuMode": "frame-time",
        "gpuMode": "latency-max-performance",
        "memoryReserveGb": 6,
        "containerBudgetGb": 0,
        "vmBudgetGb": 0,
        "modelBudgetGb": 2,
        "backgroundPriority": "throttled"
      },
      "networkPolicy": "gaming-low-latency-firewalled",
      "aihubMode": "frame-pacing-latency-background-throttle",
      "dashboardWidgets": ["fps", "frame-time", "gpu", "cpu", "memory", "storage-latency", "network-latency", "security"]
    },
    {
      "id": "studio",
      "displayName": "Studio",
      "windowsRole": "standard-user",
      "interactive": true,
      "admin": false,
      "color": "#D64DFF",
      "glyph": "WAVE",
      "soundCue": "profile-studio",
      "background": "waveform-grass-violet",
      "softwareBundles": ["common-core", "studio-audio", "studio-video", "studio-3d", "studio-plugins"],
      "roots": ["studio", "models-media", "common", "crosspartition-sanitized", "renders"],
      "resourcePolicy": {
        "cpuMode": "audio-realtime",
        "gpuMode": "render-balanced",
        "memoryReserveGb": 12,
        "containerBudgetGb": 4,
        "vmBudgetGb": 0,
        "modelBudgetGb": 12,
        "backgroundPriority": "audio-critical"
      },
      "networkPolicy": "plugin-and-cloud-approved",
      "aihubMode": "asio-plugin-index-render-optimize",
      "dashboardWidgets": ["asio", "buffer", "xruns", "cpu", "gpu", "memory", "disk-stream", "plugins", "renders", "security"]
    },
    {
      "id": "personal",
      "displayName": "Personal",
      "windowsRole": "standard-user",
      "interactive": true,
      "admin": false,
      "color": "#BBD7FF",
      "glyph": "HOME",
      "soundCue": "profile-personal",
      "background": "calm-grass-silver-blue",
      "softwareBundles": ["common-core", "personal-productivity", "personal-media", "personal-communications"],
      "roots": ["personal", "common", "crosspartition-sanitized", "backups-user"],
      "resourcePolicy": {
        "cpuMode": "balanced-quiet",
        "gpuMode": "balanced",
        "memoryReserveGb": 6,
        "containerBudgetGb": 0,
        "vmBudgetGb": 0,
        "modelBudgetGb": 4,
        "backgroundPriority": "low-noise"
      },
      "networkPolicy": "normal-protected",
      "aihubMode": "quiet-assistant-privacy-backup",
      "dashboardWidgets": ["privacy", "backup", "security", "storage", "memory", "network"]
    },
    {
      "id": "server-background",
      "displayName": "Server / Background",
      "windowsRole": "service-identities",
      "interactive": false,
      "admin": false,
      "color": "#6D7B8D",
      "glyph": "DAEMON",
      "soundCue": "none",
      "background": "graphite-service-mesh",
      "softwareBundles": ["server-runtime", "server-containers", "server-observability", "server-security", "server-ai-workers"],
      "roots": ["server", "models-service", "telemetry", "backups-service"],
      "resourcePolicy": {
        "cpuMode": "efficient-always-on",
        "gpuMode": "worker-scheduled",
        "memoryReserveGb": 8,
        "containerBudgetGb": 48,
        "vmBudgetGb": 48,
        "modelBudgetGb": 32,
        "backgroundPriority": "service-controlled"
      },
      "networkPolicy": "deny-by-default-service-allowlist",
      "aihubMode": "scheduled-monitor-backup-worker-routing",
      "dashboardWidgets": ["uptime", "queues", "services", "firewall", "containers", "vms", "models", "memory", "power", "backup"]
    }
  ]
}