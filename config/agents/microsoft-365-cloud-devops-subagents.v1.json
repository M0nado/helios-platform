      "allowed": ["repository-inventory", "classify-repository", "issue-link", "pr-create", "workflow-read", "codespace-config-plan", "copilot-instruction-plan", "promotion-map"],
      "denied": ["blind-archive", "direct-enterprise-mirror-push", "force-push-protected-branch", "secret-copy", "bypass-required-checks", "delete-repository"],
      "requiresApprovalFor": ["merge", "archive-repository", "protected-branch-change", "enterprise-promotion", "codespace-secret-change"],
      "healthChecks": ["canonical-repo-read", "companion-fleet-repo-read", "branch-protection-readiness", "actions-readiness", "codespaces-config-readiness"],
      "evidence": ["repository-classification", "promotion-chain", "workflow-status", "immutable-source-sha"]
    },
    {
      "id": "foundry-agent-service",
      "name": "Microsoft Foundry Agent Service Subagent",
      "parentAgent": "foundry-platform",
      "runtime": "azure-ai-foundry+agent-service+entra-agent-id",
      "purpose": "Manage Foundry project readiness, Agent Service definitions, Entra Agent identities, model deployments, evaluations, tool connections, tracing, and approved publication handoffs.",
      "allowed": ["project-readiness", "agent-definition-validate", "model-deployment-plan", "tool-connection-plan", "evaluation-run", "trace-read", "entra-agent-registration-plan"],
      "denied": ["unapproved-model-deploy", "unbounded-tool-connection", "tenant-wide-agent-registration", "credential-inline", "production-publish-without-review"],
      "requiresApprovalFor": ["model-deploy", "agent-publish", "new-tool-connection", "entra-agent-registration", "capacity-change"],
      "healthChecks": ["foundry-project-resolve", "model-catalog-read", "agent-service-readiness", "evaluation-readiness", "application-insights-trace-readiness"],
      "evidence": ["agent-definition", "model-policy-summary", "evaluation-report", "trace-link"]
    },
    {
      "id": "unified-cli-control",
      "name": "Unified HELIOS CLI Control Subagent",
      "parentAgent": "azure-toolchain",
      "runtime": "pwsh+dotnet-tool+node-cli+python-cli",
      "purpose": "Expose one easy HELIOS command surface that routes to az, azd, Bicep, Functions, PAC, M365, GitHub, Azure DevOps, Docker, .NET, Node, Python, and XCore tools.",
      "allowed": ["tool-discover", "version-report", "command-plan", "dry-run", "route-to-specialist", "collect-output", "open-documentation"],
      "denied": ["arbitrary-shell", "credential-echo", "implicit-production", "unsafe-command-concatenation", "unapproved-package-install", "destructive-default"],
      "requiresApprovalFor": ["elevated-command", "write-command", "production-command", "package-install", "extension-install"],
      "healthChecks": ["toolchain-manifest-load", "command-router-test", "argument-escaping-test", "dry-run-test", "secret-redaction-test"],
      "evidence": ["command-plan", "tool-version-map", "redacted-execution-result", "approval-record"]
    }
  ]
}
