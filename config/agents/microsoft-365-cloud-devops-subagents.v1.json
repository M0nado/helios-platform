{
  "schemaVersion": "1.0",
  "registryId": "helios-microsoft-365-cloud-devops-subagents",
  "parentFleet": "helios-enterprise-deployment-fleet",
  "parentIssue": 165,
  "productionBlockerIssue": 162,
  "defaultMode": "plan-and-validate",
  "subagents": [
    {
      "id": "m365-copilot-orchestrator",
      "name": "Microsoft 365 Copilot Orchestrator",
      "parentAgent": "microsoft-graph",
      "runtime": "csharp+graph+copilot-studio+agents-toolkit",
      "purpose": "Provide one normal Microsoft 365 Copilot front door that delegates bounded Outlook, Teams, SharePoint, OneDrive, Planner, Word, Excel, PowerPoint, and Copilot Studio tasks.",
      "allowed": ["intent-classify", "delegate-m365-specialist", "readiness-check", "approval-request", "result-compose", "evidence-link"],
      "denied": ["tenant-wide-agent-publish", "automatic-admin-consent", "bulk-user-data-export", "cross-user-impersonation", "secret-readback", "approval-bypass"],
      "requiresApprovalFor": ["new-graph-scope", "production-agent-publish", "cross-site-write", "external-share"],
      "healthChecks": ["graph-profile-read", "teams-resolve", "sharepoint-governance-resolve", "onedrive-root-read", "copilot-studio-environment-readiness"],
      "evidence": ["delegation-trace", "graph-scope-summary", "m365-operation-links", "approval-record"]
    },
    {
      "id": "m365-productivity-specialists",
      "name": "Microsoft 365 Productivity Specialist Pool",
      "parentAgent": "microsoft-graph",
      "runtime": "graph+office-connectors",
      "purpose": "Expose bounded Outlook, Teams, SharePoint, OneDrive, Planner, Word, Excel, PowerPoint, and Loop specialists behind the Copilot orchestrator.",
      "allowed": ["outlook-draft", "teams-message", "sharepoint-publish", "onedrive-file-operation", "planner-task-operation", "office-document-plan", "loop-workspace-plan"],
      "denied": ["send-without-explicit-request", "delete-user-content", "anonymous-share", "unscoped-tenant-search", "macro-execution", "credential-export"],
      "requiresApprovalFor": ["email-send", "file-delete", "permission-change", "external-share", "planner-delete"],
      "healthChecks": ["outlook-readiness", "teams-readiness", "sharepoint-readiness", "onedrive-readiness", "planner-readiness", "office-app-readiness"],
      "evidence": ["operation-summary", "destination-links", "permission-diff", "correlation-id"]
    },
    {
      "id": "edge-copilot-workspace",
      "name": "Microsoft Edge Copilot Workspace Subagent",
      "parentAgent": "custom-connection-manager",
      "runtime": "edge+browser-policy+chatgpt-app+mcp",
      "purpose": "Coordinate approved Edge workspaces and links for Microsoft 365 Copilot, Azure Portal, Cloud Shell, GitHub, Linear, SharePoint, Teams, and HELIOS GUI surfaces.",
      "allowed": ["workspace-manifest", "approved-link-open", "browser-readiness", "edge-policy-read", "extension-readiness", "safe-deep-link"],
      "denied": ["private-browser-data-export", "silent-extension-install", "arbitrary-page-script", "cross-profile-access", "credential-readback"],
      "requiresApprovalFor": ["extension-install", "browser-policy-write", "workspace-share"],
      "healthChecks": ["edge-version", "profile-resolution", "approved-url-validation", "m365-copilot-url-readiness", "azure-portal-url-readiness"],
      "evidence": ["workspace-manifest", "policy-readiness-report", "validated-links"]
    },
    {
      "id": "azure-cloud-shell",
      "name": "Azure Cloud Shell Subagent",
      "parentAgent": "azure-cli-bootstrap",
      "runtime": "azure-cloud-shell+az+pwsh+bash",
      "purpose": "Provide a zero-local-install Azure command surface for discovery, Bicep compilation, what-if, logs, and approved deployment operations.",
      "allowed": ["cloud-shell-readiness", "az-account-show", "subscription-list", "bicep-build", "what-if", "resource-read", "log-query", "artifact-upload-plan"],
      "denied": ["implicit-subscription-selection", "credential-export", "owner-role-grant", "unapproved-production-apply", "persistent-data-delete", "shell-secret-write"],
      "requiresApprovalFor": ["subscription-selection", "rbac-write", "production-apply", "resource-delete"],
      "healthChecks": ["cloud-shell-launch", "az-version", "pwsh-version", "storage-mount-readiness", "tenant-context", "subscription-context"],
      "evidence": ["cloud-shell-session-metadata", "command-plan", "what-if-link", "azure-correlation-id"]
    },
    {
