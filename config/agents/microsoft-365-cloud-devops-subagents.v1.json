      "parentAgent": "custom-connection-manager",
      "runtime": "azure-devops-cli+mcp+rest",
      "purpose": "Connect HELIOS to Azure DevOps projects, repositories, pipelines, boards, artifacts, environments, and service connections while GitHub remains canonical.",
      "allowed": ["org-readiness", "project-inventory", "repo-read", "pipeline-read", "board-read", "artifact-read", "service-connection-plan", "mirror-plan"],
      "denied": ["canonical-source-replacement", "pipeline-run-without-approval", "secret-export", "organization-admin-grant", "force-push", "history-delete"],
      "requiresApprovalFor": ["pipeline-run", "service-connection-write", "repo-mirror-write", "environment-approval-change"],
