{
  "schemaVersion": 1,
  "name": "HELIOS Windows boot security and rootkit recovery",
  "defaultMode": "audit",
  "startup": {
    "auditTask": true,
    "automaticOfflineScan": false,
    "reportDirectory": "%ProgramData%\\HELIOS\\Security\\Reports"
  },
  "scheduledScans": {
    "dailyQuickScan": true,
    "dailyQuickScanTime": "12:30",
    "weeklyFullScanDefault": false,
    "fullScanRequiresExplicitOptIn": true
  },
  "defender": {
    "realTimeProtection": true,
    "behaviorMonitoring": true,
    "scriptScanning": true,
    "ioavProtection": true,
    "cloudProtection": "high",
    "puaProtection": "enabled",
    "networkProtection": "enabled",
    "controlledFolderAccessDefault": "audit"
  },
  "attackSurfaceReduction": {
    "defaultAction": "audit",
    "strictAction": "block",
    "rules": [
      { "id": "56a863a9-875e-4185-98a7-b882c64b5ce5", "name": "Block abuse of exploited vulnerable signed drivers" },
      { "id": "9e6c4e1f-7d60-472f-ba1a-a39ef669e4b2", "name": "Block credential stealing from LSASS" },
      { "id": "e6db77e5-3df2-4cf1-b95a-636979351e5b", "name": "Block persistence through WMI event subscription" },
      { "id": "5beb7efe-fd9a-4556-801d-275e5ffc04cc", "name": "Block execution of potentially obfuscated scripts" },
      { "id": "d3e037e1-3eb8-44c8-a917-57927947596d", "name": "Block JavaScript or VBScript from launching downloaded executable content" },
      { "id": "c1db55ab-c21a-4637-bb3f-a12568109d35", "name": "Use advanced protection against ransomware" }
    ]
  },
  "bootChain": {
    "secureBoot": "audit-firmware-required",
    "tpm2": "audit-firmware-required",
    "memoryIntegrity": "explicit-opt-in",
    "credentialGuard": "explicit-opt-in",
    "vulnerableDriverBlocklist": "enable"
  },
  "rootkitRecovery": {
    "provider": "Microsoft Defender Offline",
    "requiresWinRE": true,
    "bitLockerSuspendReboots": 1,
    "confirmationPhrase": "RUN HELIOS OFFLINE ROOTKIT SCAN"
  }
}
