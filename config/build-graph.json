{
  "nodes": [
    {
      "id": "toolchain-ready",
      "title": "Local toolchain readiness",
      "command": "python3 -c \"import shutil,sys; missing=[t for t in ['git','python3'] if shutil.which(t) is None]; print('missing: '+', '.join(missing) if missing else 'toolchain ready'); sys.exit(1 if missing else 0)\"",
      "paths": [
        "scripts/setup/**",
        "config/build-graph.json"
      ],
      "tags": [
        "setup",
        "quick"
      ],
      "timeoutSeconds": 30
    },
    {
      "id": "dotnet-ready",
      "title": ".NET SDK readiness",
      "command": "python3 -c \"import shutil,sys; print('dotnet ready' if shutil.which('dotnet') else 'dotnet not found'); sys.exit(0 if shutil.which('dotnet') else 1)\"",
      "paths": [
        "src/**",
        "tests/**",
        "config/build-graph.json"
      ],
      "tags": [
        "setup",
        "dotnet"
      ],
      "dependsOn": [
        "toolchain-ready"
      ],
      "timeoutSeconds": 30
    },
    {
      "id": "cmake-ready",
      "title": "CMake readiness",
      "command": "python3 -c \"import shutil,sys; print('cmake ready' if shutil.which('cmake') else 'cmake not found'); sys.exit(0 if shutil.which('cmake') else 1)\"",
      "paths": [
        "src/native/**",
        "config/build-graph.json"
      ],
      "tags": [
        "setup",
        "native",
        "cpp"
      ],
      "timeoutSeconds": 30
    },
    {
      "id": "azure-cli-ready",
      "title": "Azure CLI readiness",
      "command": "python3 -c \"import shutil,sys; print('az ready' if shutil.which('az') else 'az not found'); sys.exit(0 if shutil.which('az') else 1)\"",
      "paths": [
        "infra/azure/**",
        "scripts/azure/**",
        "config/build-graph.json"
      ],
      "tags": [
        "azure",
        "setup"
      ],
      "timeoutSeconds": 30
    },
    {
      "id": "azure-auth-ready",
      "title": "Azure authentication readiness",
      "command": "az account show",
      "paths": [
        "infra/azure/**",
        "scripts/azure/**"
      ],
      "tags": [
        "azure"
      ],
      "dependsOn": [
        "azure-cli-ready"
      ],
      "timeoutSeconds": 30
    },
    {
