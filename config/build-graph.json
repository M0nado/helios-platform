{
  "nodes": [
    {
      "id": "workflow-validation",
      "title": "GitHub workflow validation without PyYAML",
      "command": "python3 scripts/control/validate_workflows.py",
      "paths": [
        ".github/workflows/**",
        "scripts/control/validate_workflows.py"
      ]
    },
    {
      "id": "pr-update-body",
      "title": "Generated PR update body",
      "command": "python3 scripts/github/update-pr-from-reports.py --dry-run",
      "paths": [
        "scripts/github/update-pr-from-reports.py",
        "reports/**"
      ]
    },
    {
      "id": "doctor",
      "title": "Setup doctor",
      "command": "python3 scripts/control/doctor.py",
      "paths": [
        "scripts/control/doctor.py"
      ]
    },
    {
      "id": "readiness-score",
      "title": "Readiness score",
      "command": "python3 scripts/integrations/readiness_score.py",
      "paths": [
        "scripts/integrations/readiness_score.py",
        "reports/**"
      ]
    },
    {
      "id": "gui-dashboard",
      "title": "HTML command center GUI",
      "command": "python3 scripts/dashboard/generate-gui.py",
      "paths": [
        "scripts/dashboard/generate-gui.py",
        "status-site/**",
        "reports/**"
      ]
    },
    {
      "id": "cross-access-profiles",
      "title": "Cross-access profile readiness",
      "command": "python3 scripts/integrations/cross_access_profiles.py",
      "paths": [
        "config/cross-access-profiles.example.json",
        "config/secrets-map.example.json"
      ]
    },
    {
      "id": "hybrid-gap-analysis",
      "title": "Hybrid integration gap analysis",
      "command": "python3 scripts/analysis/hybrid_gap_analysis.py",
      "paths": [
        "config/hybrid-integration-roadmap.json",
        "reports/project-inventory/**"
      ]
    },
    {
      "id": "repo-inventory",
      "title": "Whole-project inventory",
      "command": "python3 scripts/analysis/repo_inventory.py",
      "paths": [
        "**/*"
      ]
    },
    {
      "id": "python-static",
      "title": "Python static compile checks",
      "command": "python3 scripts/control/python_static.py",
      "paths": [
        "scripts/**/*.py"
      ]
    },
    {
      "id": "analytics-tests",
      "title": "F# analytics tests",
      "command": "dotnet test tests/analytics/HELIOS.Analytics.FSharp.Tests/HELIOS.Analytics.FSharp.Tests.fsproj --no-restore",
      "paths": [
        "src/analytics/**",
        "tests/analytics/**"
      ]
    },
    {
      "id": "native-configure",
      "title": "Native/XCore CMake configure",
      "command": "cmake -S src/native/HELIOS.Native.Performance -B .build/native",
      "paths": [
        "src/native/**"
      ]
    },
    {
      "id": "native-build",
      "title": "Native/XCore CMake build",
      "command": "cmake --build .build/native",
      "paths": [
        "src/native/**"
      ],
      "dependsOn": [
        "native-configure"
      ]
    },
    {
      "id": "branch-intelligence",
      "title": "Branch and remote intelligence reports",
      "command": "python3 scripts/analysis/branch_intelligence.py",
      "paths": [
        "scripts/analysis/**",
        "docs/integration/remote-manifest.json",
        "reports/branch-intelligence/**"
      ]
    },
    {
      "id": "graphs",
      "title": "Graph reports",
      "command": "python3 scripts/graphs/generate_graphs.py",
      "paths": [
        "scripts/graphs/**",
        "reports/branch-intelligence/**"
      ]
    },
    {
      "id": "control-summary",
      "title": "Control summary",
      "command": "python3 scripts/control/helios-control.py",
      "paths": [
        "scripts/control/**",
        "config/*.json"
      ]
    },
    {
      "id": "azure-bicep",
      "title": "Azure Bicep build",
      "command": "python3 scripts/azure/bicep_report.py build",
      "paths": [
        "infra/azure/**"
      ]
    },
    {
      "id": "dotnet-workloads",
      "title": ".NET workload visibility for MAUI/Visual Studio readiness",
      "command": "dotnet workload list",
      "paths": [
        "src/**",
        "tests/**"
      ]
    },
    {
      "id": "maui-readiness",
      "title": "MAUI readiness placeholder",
      "command": "dotnet --info",
      "paths": [
        "src/**"
      ]
    },
    {
      "id": "visual-studio-readiness",
      "title": "Visual Studio developer machine readiness guidance",
      "command": "python3 -c \"print('Visual Studio/MAUI readiness is documented; install VS with .NET MAUI workload on Windows/macOS.')\"",
      "paths": [
        "docs/integration/VISUAL_STUDIO_MAUI_SETUP.md"
      ]
    },
    {
      "id": "app-automation-readiness",
      "type": "python",
      "path": "scripts/integrations/app_automation.py",
      "command": "python3 scripts/integrations/app_automation.py",
      "outputs": [
        "reports/integrations/app-automation-readiness.json",
        "reports/integrations/app-automation-readiness.md"
      ],
      "title": "App automation readiness",
      "paths": [
        "scripts/integrations/app_automation.py",
        "config/integrations.example.json",
        "config/secrets-map.example.json"
      ]
    },
    {
      "id": "local-app-shell",
      "title": "Local app shell launcher",
      "command": "bash -n scripts/local-app/helios-local-app.sh",
      "paths": [
        "scripts/local-app/**",
        "docs/integration/LOCAL_APP_SHELL.md"
      ]
    },
    {
      "id": "remote-inventory",
      "title": "Safe remote inventory for helios-control/hermes-fleet-production/xcore",
      "command": "python3 scripts/analysis/branch_intelligence.py --remote-inventory-only",
      "paths": [
        "docs/integration/remote-manifest.json",
        "scripts/analysis/branch_intelligence.py"
      ]
    },
    {
      "id": "repository-analytics",
      "title": "F# repository analytics bridge for branch and Hermes scores",
      "command": "dotnet run --project src/tools/HELIOS.RepositoryAnalytics/HELIOS.RepositoryAnalytics.csproj",
      "paths": [
        "src/tools/HELIOS.RepositoryAnalytics/**",
        "src/analytics/**",
        "reports/branch-intelligence/analytics-metrics.json"
      ],
      "dependsOn": [
        "branch-intelligence"
      ]
    },
    {
      "id": "native-benchmark",
      "title": "Native/XCore C++ benchmark smoke test",
      "command": "cmake --build .build/native --target HELIOSNativePerformanceBenchmark && .build/native/HELIOSNativePerformanceBenchmark",
      "paths": [
        "src/native/**"
      ],
      "dependsOn": [
        "native-configure",
        "native-build"
      ]
    },
    {
      "id": "native-csharp-smoke",
      "title": "C# Native/XCore interop smoke project build",
      "command": "python3 scripts/native/run_csharp_native_smoke.py",
      "dependsOn": [
        "native-configure",
        "native-build"
      ],
      "paths": [
        "samples/native-interop/**",
        "src/native/**"
      ]
    },
    {
      "id": "native-python-smoke",
      "title": "Python Native/XCore ctypes smoke script syntax",
      "command": "python3 -m py_compile scripts/native/native_smoke.py && python3 scripts/native/native_smoke.py",
      "paths": [
        "scripts/native/native_smoke.py",
        "src/native/**"
      ],
      "dependsOn": [
        "native-configure",
        "native-build"
      ]
    },
    {
      "id": "full-stack-readiness",
      "title": "Full-stack tool and path readiness report",
      "command": "python3 scripts/integrations/full_stack_readiness.py",
      "paths": [
        "scripts/integrations/full_stack_readiness.py",
        "config/build-graph.json",
        "docs/integration/remote-manifest.json"
      ]
    }
  ]
}
