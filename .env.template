# API Keys for HELIOS AI Services
# IMPORTANT: Never commit this file to Git!
# This file is in .gitignore and should be kept private

# ============================================================================
# Azure deployment and runtime integration
# GitHub Actions deploys use OIDC with AZURE_CLIENT_ID / AZURE_TENANT_ID /
# AZURE_SUBSCRIPTION_ID. The cloud-integration runtime still expects a client
# secret today, so keep AZURE_CLIENT_SECRET populated until that code path is
# migrated.
# ============================================================================
export AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
export AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
export AZURE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
export AZURE_CLIENT_SECRET="YOUR_AZURE_CLIENT_SECRET"
export AZURE_RESOURCE_GROUP="rg-helios"
export AZURE_LOCATION="eastus"
export HELIOS_ENVIRONMENT="prod"
export HELIOS_BASE_NAME="helios"
export HELIOS_RESOURCE_GROUP="rg-helios"
export HELIOS_LOCATION="eastus"
export HELIOS_DEPLOY_OBSERVABILITY=true
export HELIOS_PARAMETERS_FILE=""
export DEPLOYMENT_OUTPUT_DIR="./deployment-artifacts"
export DEPLOYMENT_STATUS_WEBHOOK="https://example.com/helios/deployments"
export AZURE_LOG_ANALYTICS_WORKSPACE="/subscriptions/<sub>/resourceGroups/rg-helios/providers/Microsoft.OperationalInsights/workspaces/helios-prod-log"
export AZURE_APP_INSIGHTS_KEY="00000000-0000-0000-0000-000000000000"
export AZURE_KEYVAULT_NAME="helios-prod-kv"

# Optional deployment overrides
export CONTROL_PLANE_IMAGE="ghcr.io/m0nado/helios-platform/control-plane:latest"
export HUBSPOT_SYNC_IMAGE="ghcr.io/m0nado/helios-platform/hubspot-sync:latest"
export AKS_IMAGE="ghcr.io/m0nado/helios-platform/control-plane:latest"
export HUBSPOT_BASE_URL="https://api.hubapi.com"
export SLACK_CHANNEL="#helios-alerts"
export SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
export HUBSPOT_PRIVATE_APP_TOKEN="YOUR_HUBSPOT_PRIVATE_APP_TOKEN"

# ============================================================================
# ChatGPT Pro (GPT-4)
# Get key at: https://platform.openai.com/account/api-keys
# ============================================================================
export CHATGPT_API_KEY="sk-YOUR_CHATGPT_KEY_HERE"
export CHATGPT_MODEL="gpt-4"
export CHATGPT_ENABLED=true

# ============================================================================
# Codex
# Get key at: https://platform.openai.com/account/api-keys
# ============================================================================
export CODEX_API_KEY="sk-YOUR_CODEX_KEY_HERE"
export CODEX_MODEL="code-davinci-002"
export CODEX_TEMPERATURE=0.2
export CODEX_ENABLED=true

# ============================================================================
# GPT-4.5 (Latest Model)
# Get key at: https://platform.openai.com/account/api-keys
# ============================================================================
export GPT45_API_KEY="sk-YOUR_GPT45_KEY_HERE"
export GPT45_MODEL="gpt-4-turbo-2024-04"
export GPT45_ENABLED=true

# ============================================================================
# Cost Limits (USD per month)
# ============================================================================
export COST_LIMIT_TOTAL=300
export COST_LIMIT_CHATGPT=100
export COST_LIMIT_CODEX=50
export COST_LIMIT_GPT45=150

# ============================================================================
# Rate Limiting
# ============================================================================
export RATE_LIMIT_REQUESTS_PER_MINUTE=30
export RATE_LIMIT_REQUESTS_PER_DAY=500

# ============================================================================
# Hub Configuration
# ============================================================================
export AI_HUB_DEBUG=false
export AI_HUB_DRY_RUN=false
export AI_HUB_AUTO_APPROVE_THRESHOLD=0.95
export AI_HUB_CONFLICT_STRATEGY="consensus"

# ============================================================================
# Setup Instructions
# ============================================================================
# 1. Get your API keys from https://platform.openai.com/account/api-keys
# 2. Replace the placeholder values above with your actual keys
# 3. Run: source .env (on Unix/Mac/WSL) or copy values to PowerShell profile (Windows)
# 4. Verify: .\scripts\ai-services\validate-keys.ps1
# 5. Test: .\scripts\ai-services\test-services.ps1
