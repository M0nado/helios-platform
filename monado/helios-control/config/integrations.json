{
  "schemaVersion": 1,
  "executionMode": "dry-run",
  "runtimeBindings": "disabled-no-outbound-workers-or-provider-credentials",
  "routingState": "planned-not-executable",
  "identity": { "azureCredential": "managed-identity", "secretStore": "key-vault" },
  "enterprise": {
    "codeAuthority": "github-enterprise",
    "deliveryBridge": "azure-devops",
    "authentication": "entra-workload-identity-oidc",
    "agentPolicy": "tiered-pr-first",
    "copilots": ["github-copilot", "codex", "microsoft-365-copilot", "copilot-studio", "microsoft-foundry-agent-service"],
    "repositories": ["Yolkster64/monado-blade", "M0nado/helios-platform"],
    "secretPolicy": "key-vault-or-local-vault-never-repository"
  },
  "destinations": {
    "github": { "account": "M0nado", "repository": "M0nado/helios-platform", "path": "monado/helios-control", "enabled": false, "bindingState": "governance-reference-only-no-runtime-writer" },
    "linear": { "team": "${LINEAR_TEAM_NAME}", "project": "${LINEAR_PROJECT_NAME}", "enabled": false, "bindingState": "unbound-placeholder" },
    "slack": { "workspace": "${SLACK_WORKSPACE_NAME}", "channel": "${SLACK_CHANNEL_NAME}", "enabled": false, "bindingState": "unbound-placeholder" },
    "teams": { "team": "${TEAMS_TEAM_NAME}", "channel": "${TEAMS_CHANNEL_NAME}", "enabled": false, "bindingState": "unbound-placeholder" },
    "sharepoint": { "tenant": "${SHAREPOINT_TENANT_HOST}", "library": "${SHAREPOINT_LIBRARY}", "folder": "${SHAREPOINT_GOVERNANCE_FOLDER}", "enabled": false, "bindingState": "unbound-placeholder" },
    "microsoftAgents": { "registry": "entra-agent-registry", "manifest": "config/microsoft-agents.json", "toolchain": "config/microsoft-toolchain.json", "runtime": "microsoft-foundry-agent-service", "channels": ["microsoft-365-copilot", "teams"], "enabled": false, "bindingState": "planned-not-published" }
  },
  "routing": [
    { "event": "github.workflow.failed", "enabled": false, "targets": ["linear", "slack", "teams"] },
    { "event": "linear.issue.updated", "enabled": false, "targets": ["github", "slack", "teams"] },
    { "event": "hermes.training.candidate", "enabled": false, "targets": ["microsoftAgents", "sharepoint"] },
    { "event": "hermes.training.approved", "enabled": false, "targets": ["github", "microsoftAgents", "slack", "teams"] },
    { "event": "sharepoint.document.updated", "enabled": false, "targets": ["linear"] }
  ]
}
