{
  "schemaVersion": 1,
  "runtime": "microsoft-foundry-agent-service",
  "distribution": ["microsoft-365-copilot", "microsoft-teams", "agent-365-registry"],
  "sharedToolbox": {
    "protocol": "mcp",
    "endpoint": "azure-functions:/runtime/webhooks/mcp",
    "authentication": "entra-managed-identity",
    "tools": ["hermes.get_status", "hermes.list_routes", "hermes.list_candidates", "github.read_pr", "azuredevops.read_work_item"]
  },
  "agents": [
    {
      "id": "hermes-orchestrator",
      "type": "hosted",
      "purpose": "Route XCore tasks across inference, feature engineering, and training nodes.",
      "permissionTier": 2,
      "writes": "draft-only"
    },
    {
      "id": "xcore-teacher",
      "type": "hosted",
      "purpose": "Generate weakness-aware synthetic tasks and controlled curriculum mutations.",
      "permissionTier": 2,
      "writes": "sandbox-memory-only"
    },
    {
      "id": "xcore-evaluator",
      "type": "prompt",
      "purpose": "Score quality, latency, safety, regression, and evidence completeness.",
      "permissionTier": 1,
      "writes": "evaluation-store-only"
    },
    {
      "id": "helios-governor",
      "type": "prompt",
      "purpose": "Enforce data classification, approval thresholds, promotion gates, and rollback policy.",
      "permissionTier": 3,
      "writes": "pull-request-only"
    }
  ],
  "learningPolicy": {
    "rawCopilotConversationsAsTrainingData": false,
    "allowedSources": ["approved-tests", "synthetic-curriculum", "reviewed-documents", "sanitized-telemetry"],
    "candidateStore": "cosmosdb:hermes-learning/candidates",
    "vectorStore": "azure-ai-search:hermes-memory",
    "evidenceStore": "datalake:helios/evaluations",
    "promotion": "evaluation-pass-plus-human-approval-plus-pull-request",
    "automaticProductionMutation": false,
    "rollbackRequired": true
  }
}
