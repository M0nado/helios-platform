{
  "name": "helios-platform-automation",
  "private": true,
  "version": "1.0.0",
  "description": "Repository automation metadata for HELIOS Platform.",
  "scripts": {
    "validate:workflows": "python3 scripts/github/validate-workflows.py",
    "consolidation:dry-run": "python3 scripts/github/prepare-consolidation.py --online --dry-run --write-gitmodules-preview --allow-unreachable",
    "consolidation:gate": "python3 scripts/github/prepare-consolidation.py --online --dry-run --write-gitmodules-preview --fail-on-unreachable",
    "consolidation:offline": "python3 scripts/github/prepare-consolidation.py --offline --dry-run --write-gitmodules-preview"
  }
}
