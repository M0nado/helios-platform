      "id": "tools",
      "confirmation": "INSTALL-HELIOS-TOOLS",
      "operations": [
        "install-azure-cli",
        "install-azd",
        "install-functions-tools",
        "install-powershell",
        "install-github-cli",
        "install-node-lts",
        "install-m365-agents-toolkit",
        "install-claude-code",
        "install-slack-claude-plugin",
        "install-azure-devops-extension"
      ]
    },
    {
      "id": "authenticate",
      "confirmation": "AUTHENTICATE-HELIOS",
      "operations": [
        "azure-interactive-login",
        "azd-interactive-login",
        "github-interactive-login",
        "power-platform-interactive-login",
        "agent365-interactive-login"
