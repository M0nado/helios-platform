{
  "version": 1,
  "default_target_branch": "work",
  "priority_sources": [
    "helios-control",
    "hermes-fleet-production"
  ],
  "conflict_resolution_ownership": {
    "csharp_winui": "helios-control owns WinUI 3 shell, C# front-end flows, XAML resources, MVVM/service wiring, and end-user control surfaces.",
    "cpp_backend": "helios-monado-blade owns C++ performance backend, native interop boundaries, low-latency paths, security-sensitive native optimization, and Hermes XCore specialist hooks.",
    "fsharp_analytics": "hermes-fleet-production owns F# math, prediction, analytics, fleet optimization models, parallel analytics semantics, and production telemetry interpretation.",
    "python_ai_hub": "helios-ai-hub owns Python AI Hub integration, model orchestration, agent connectors, notebooks/scripts, and AI workflow compatibility.",
    "azure_github_automation": "helios-build-agents owns Azure CLI, GitHub Actions, CI/CD, release automation, provisioning scripts, and cloud deployment workflows."
  },
  "sources": [
    {
      "id": "helios-platform",
      "kind": "current_repository",
      "remote": "origin",
      "url": "https://github.com/M0nado/helios-platform.git",
      "branch": "work",
      "order": 0,
      "mode": "history",
      "path": ".",
      "areas": ["integration_baseline", "documentation"]
    },
    {
      "id": "helios-control",
      "kind": "external_repository",
      "remote": "helios-control",
      "url": "https://github.com/M0nado/helios-control.git",
      "branch": "main",
      "order": 1,
      "mode": "subtree",
      "path": "modules/helios-control",
      "areas": ["csharp_winui", "control_plane", "user_experience"]
    },
    {
      "id": "hermes-fleet-production",
      "kind": "external_repository",
      "remote": "hermes-fleet-production",
      "url": "https://github.com/M0nado/hermes-fleet-production.git",
      "branch": "main",
      "order": 2,
      "mode": "subtree",
      "path": "modules/hermes-fleet-production",
      "areas": ["fsharp_analytics", "fleet_production", "prediction_models", "parallel_analytics"]
    },
    {
      "id": "helios-monado-blade",
      "kind": "external_repository",
      "remote": "helios-monado-blade",
      "url": "https://github.com/M0nado/helios-monado-blade.git",
      "branch": "main",
      "order": 3,
      "mode": "submodule",
      "path": "modules/helios-monado-blade",
      "areas": ["cpp_backend", "performance", "native_security", "hermes_xcore"]
    },
    {
      "id": "helios-security-setup",
      "kind": "external_repository",
      "remote": "helios-security-setup",
      "url": "https://github.com/M0nado/helios-security-setup.git",
      "branch": "main",
      "order": 4,
      "mode": "submodule",
      "path": "modules/helios-security-setup",
      "areas": ["security", "hardening", "compliance"]
    },
    {
      "id": "helios-ai-hub",
      "kind": "external_repository",
      "remote": "helios-ai-hub",
      "url": "https://github.com/M0nado/helios-ai-hub.git",
      "branch": "main",
      "order": 5,
      "mode": "submodule",
      "path": "modules/helios-ai-hub",
      "areas": ["python_ai_hub", "model_orchestration", "ai_integration"]
    },
    {
      "id": "helios-dev-ai-hub",
      "kind": "external_repository",
      "remote": "helios-dev-ai-hub",
      "url": "https://github.com/M0nado/helios-dev-ai-hub.git",
      "branch": "main",
      "order": 6,
      "mode": "submodule",
      "path": "modules/helios-dev-ai-hub",
      "areas": ["python_ai_hub", "development_ai_workflows", "experimentation"]
    },
    {
      "id": "helios-build-agents",
      "kind": "external_repository",
      "remote": "helios-build-agents",
      "url": "https://github.com/M0nado/helios-build-agents.git",
      "branch": "main",
      "order": 7,
      "mode": "submodule",
      "path": "modules/helios-build-agents",
      "areas": ["azure_github_automation", "azure_cli", "github_actions", "cicd"]
    },
    {
      "id": "helios-gui-framework",
      "kind": "external_repository",
      "remote": "helios-gui-framework",
      "url": "https://github.com/M0nado/helios-gui-framework.git",
      "branch": "main",
      "order": 8,
      "mode": "submodule",
      "path": "modules/helios-gui-framework",
      "areas": ["csharp_winui", "gui_framework", "shared_ui_components"]
    },
    {
      "id": "helios-software-stack",
      "kind": "external_repository",
      "remote": "helios-software-stack",
      "url": "https://github.com/M0nado/helios-software-stack.git",
      "branch": "main",
      "order": 9,
      "mode": "submodule",
      "path": "modules/helios-software-stack",
      "areas": ["toolchain", "installer", "azure_cli", "developer_setup"]
    }
  ]
}
