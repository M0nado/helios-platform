<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HELIOS.Platform.Presentation.Pages.AIHubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#080B12">
    <Grid Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="AIHub Command Panel" FontSize="30" FontWeight="Bold" Foreground="#00D9FF" />
            <TextBlock Text="JRPG-style Hermes, XCore, and Specialist fleet control for Azure, Docker, GitHub, and local AI work." Foreground="#A7B7C7" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Padding="16" Background="#132033" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Points" Foreground="#6BE7FF" FontWeight="SemiBold" />
                    <TextBlock Text="2,500" Foreground="White" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="Bulk discounts: 5+ / 10+" Foreground="#91A4B7" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" Background="#132033" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Hermes" Foreground="#6BE7FF" FontWeight="SemiBold" />
                    <TextBlock Text="120 pts" Foreground="White" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Rapid local reasoning" Foreground="#91A4B7" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="16" Background="#132033" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="XCore" Foreground="#6BE7FF" FontWeight="SemiBold" />
                    <TextBlock Text="300 pts" Foreground="White" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Parallel performance core" Foreground="#91A4B7" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Padding="16" Background="#132033" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Specialist" Foreground="#6BE7FF" FontWeight="SemiBold" />
                    <TextBlock Text="550 pts" Foreground="White" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Security, math, analytics, integration" Foreground="#91A4B7" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="18" Background="#101827" CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Fleet Roster" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" />
                    <TextBlock Text="☑ Hermes-Prime  Lv.4  XP 320  Idle — Local routing" Foreground="#DDE9F5" />
                    <TextBlock Text="☑ XCore-Alpha   Lv.5  XP 510  Idle — Parallel optimization" Foreground="#DDE9F5" />
                    <TextBlock Text="☐ Specialist-Sec Lv.6 XP 740  Idle — Security hardening" Foreground="#DDE9F5" />
                    <TextBlock Text="☐ Azure Docker Scout Lv.1 XP 0 Training — Cloud readiness" Foreground="#91A4B7" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="18" Background="#101827" CornerRadius="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Command Actions" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" />
                    <Button Content="Bulk Buy Selected Type" />
                    <Button Content="Train Selected" />
                    <Button Content="Deploy Fleet" />
                    <Button Content="Recall Fleet" />
                    <TextBlock Text="Current mission: Azure Docker GitHub readiness sweep" TextWrapping="Wrap" Foreground="#91A4B7" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="14" Background="#132033" CornerRadius="10">
            <TextBlock Text="Integration status: Azure CLI, Docker daemon, GitHub CLI, and local Hermes models are displayed here by the AIHub fleet service." Foreground="#A7B7C7" />
        </Border>
    </Grid>
</Page>
