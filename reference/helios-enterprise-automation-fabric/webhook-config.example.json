{
  "version": "1.0",
  "url": "https://REPLACE_WITH_BROKER_HOST/hooks/linear",
  "resourceTypes": [
    "Issue",
    "Comment",
    "Project",
    "ProjectUpdate",
    "Cycle"
  ],
  "teamScope": "REPLACE_TEAM_ID_OR_ALL_PUBLIC_TEAMS",
